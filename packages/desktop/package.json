{
  "name": "@avanzare/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "AVANZARE desktop app",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "dist": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "@avanzare/engine": "*"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "33.4.11",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.avanzare.app",
    "productName": "AVANZARE",
    "directories": { "output": "release" },
    "files": ["out/**"],
    "win": { "target": "nsis" }
  }
}
