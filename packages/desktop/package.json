{
  "name": "@avanzare/desktop",
  "version": "0.3.0",
  "private": true,
  "description": "AVANZARE desktop app",
  "main": "out/main/index.js",
  "author": "AVANZARE",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "dist": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.1",
    "@napi-rs/canvas": "^1.0.2",
    "better-sqlite3": "^12.4.1",
    "exceljs": "^4.4.0",
    "imapflow": "^1.4.7",
    "mailparser": "^3.9.14",
    "mammoth": "^1.8.0",
    "nodemailer": "^6.9.16",
    "pdfjs-dist": "^3.11.174",
    "tesseract.js": "^7.0.0",
    "word-extractor": "^1.0.4"
  },
  "devDependencies": {
    "@avanzare/engine": "*",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "33.4.11",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.avanzare.app",
    "productName": "AVANZARE",
    "directories": { "output": "release" },
    "files": ["out/**"],
    "npmRebuild": false,
    "asarUnpack": ["**/*.node"],
    "win": { "target": "nsis" },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
